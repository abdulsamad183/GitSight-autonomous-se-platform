# =============================================================================
# GitSight Backend — Environment Variables
# Copy this file to .env and fill in your values. Never commit .env to git.
# =============================================================================

# -----------------------------------------------------------------------------
# Core
# -----------------------------------------------------------------------------
ENV=development

# Async PostgreSQL URL (Supabase pooler in production, port 6543).
# Local example:
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/gitsight
# Supabase pooler example:
# DATABASE_URL=postgresql+asyncpg://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# JWT signing key. Use a random 32+ character string in production.
SECRET_KEY=change-me-in-production

# -----------------------------------------------------------------------------
# Required API keys
# -----------------------------------------------------------------------------
GROQ_API_KEY=

# Recommended for higher GitHub API rate limits (public repo clone and PR sync).
GITHUB_TOKEN=

# -----------------------------------------------------------------------------
# CORS and cookies (production)
# -----------------------------------------------------------------------------
# JSON array or comma-separated list of allowed origins.
# CORS_ORIGINS=["http://localhost:3000","https://your-app.vercel.app"]
# COOKIE_SAMESITE=lax

# -----------------------------------------------------------------------------
# Optional: Supabase (not required for core API; reserved for future use)
# -----------------------------------------------------------------------------
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# JWT (optional overrides)
# -----------------------------------------------------------------------------
# JWT_ALGORITHM=HS256
# JWT_EXPIRE_MINUTES=1440
# COOKIE_NAME=access_token

# -----------------------------------------------------------------------------
# Repository analysis
# -----------------------------------------------------------------------------
# CLONE_BASE_DIR=/tmp/gitsight
# MAX_FILE_SIZE_BYTES=1048576
# MAX_BRANCHES_TO_ANALYZE=1
# CLONE_DEPTH=0

# -----------------------------------------------------------------------------
# Embeddings
# -----------------------------------------------------------------------------
# Local development (default) — ONNX via fastembed
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL_NAME=BAAI/bge-small-en-v1.5
EMBEDDING_DIMENSION=384
# EMBEDDING_BATCH_SIZE=32
# EMBEDDING_THREADS=1
# EMBEDDING_GC_BETWEEN_BATCHES=false

# Production (Render) — Google Gemini Embedding API (no local model RAM)
# EMBEDDING_PROVIDER=google
# GOOGLE_API_KEY=
# EMBEDDING_MODEL_NAME=gemini-embedding-001
# EMBEDDING_DIMENSION=384
# EMBEDDING_BATCH_SIZE=16

# -----------------------------------------------------------------------------
# Search (optional tuning)
# -----------------------------------------------------------------------------
# SEARCH_DEFAULT_LIMIT=20
# SEARCH_MAX_LIMIT=100
# SEARCH_KEYWORD_WEIGHT=0.4
# SEARCH_SEMANTIC_WEIGHT=0.6
# SEARCH_SIMILARITY_THRESHOLD=0.3
# SEARCH_CANDIDATE_MULTIPLIER=3

# -----------------------------------------------------------------------------
# Code chunking (optional tuning)
# -----------------------------------------------------------------------------
# FILE_CHUNK_MAX_LINES=120
# FILE_CHUNK_WHOLE_FILE_MAX_LINES=200
# MAX_DIFF_BYTES=500000

# -----------------------------------------------------------------------------
# LLM (optional overrides)
# -----------------------------------------------------------------------------
# LLM_PROVIDER=groq
# LLM_MODEL=groq/compound-mini
# LLM_MODEL_FALLBACKS=groq/compound,meta-llama/llama-4-scout-17b-16e-instruct
# LLM_TEMPERATURE=0.2
# LLM_MAX_TOKENS=8192
# RAG_TOP_K=5
# RAG_MAX_CONTEXT_CHARS=48000
# LLM_PLANNER_MODEL=
# LLM_PLANNER_TEMPERATURE=0.0
# LLM_PLANNER_MAX_TOKENS=1024
# TOOL_MAX_STEPS=4
# GRAPH_TRAVERSAL_MAX_DEPTH=5

# -----------------------------------------------------------------------------
# Pull request review (optional tuning)
# -----------------------------------------------------------------------------
# PR_REVIEW_MAX_TOOL_STEPS=8
# PR_REVIEW_MAX_DIFF_CHUNKS=30
# PR_REVIEW_MAX_GRAPH_FILES=3
