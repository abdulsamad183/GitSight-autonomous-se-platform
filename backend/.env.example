ENV=development

# Supabase pooler (port 6543). Add ?sslmode=require if your provider requires SSL.
DATABASE_URL=postgresql+asyncpg://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

GROQ_API_KEY=
GITHUB_TOKEN=
SECRET_KEY=change-me-in-production

# Production example:
# ENV=production
# CORS_ORIGINS=["http://localhost:3000","https://your-app.vercel.app"]
# COOKIE_SAMESITE=lax

# Optional: JWT_EXPIRE_MINUTES=1440

# LLM (optional overrides)
# LLM_PROVIDER=groq
# LLM_MODEL=groq/compound-mini
# LLM_MODEL_FALLBACKS=groq/compound,meta-llama/llama-4-scout-17b-16e-instruct
# LLM_TEMPERATURE=0.2
# LLM_MAX_TOKENS=8192
# RAG_TOP_K=5
# RAG_MAX_CONTEXT_CHARS=48000
# LLM_PLANNER_MODEL=groq/compound-mini
# LLM_PLANNER_TEMPERATURE=0.0
# LLM_PLANNER_MAX_TOKENS=1024
# TOOL_MAX_STEPS=4
# GRAPH_TRAVERSAL_MAX_DEPTH=5

# Embeddings — use Google API on Render (no local model RAM)
# EMBEDDING_PROVIDER=google
# GOOGLE_API_KEY=
# EMBEDDING_MODEL_NAME=gemini-embedding-001
# EMBEDDING_DIMENSION=384

# Local dev (default) — ONNX via fastembed
# EMBEDDING_PROVIDER=local
# EMBEDDING_MODEL_NAME=BAAI/bge-small-en-v1.5
# EMBEDDING_BATCH_SIZE=8
# EMBEDDING_THREADS=1
# EMBEDDING_GC_BETWEEN_BATCHES=true

# Indexing (lower on Render free tier to reduce memory use)
# MAX_BRANCHES_TO_ANALYZE=1
