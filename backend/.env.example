ENV=development

DATABASE_URL=postgresql+asyncpg://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

GROQ_API_KEY=

# LLM (optional overrides)
# LLM_PROVIDER=groq
# LLM_MODEL=groq/compound-mini
# LLM_TEMPERATURE=0.2
# LLM_MAX_TOKENS=8192
# RAG_TOP_K=5
# RAG_MAX_CONTEXT_CHARS=48000
# LLM_PLANNER_MODEL=groq/compound-mini
# LLM_PLANNER_TEMPERATURE=0.0
# LLM_PLANNER_MAX_TOKENS=1024
# TOOL_MAX_STEPS=4
# GRAPH_TRAVERSAL_MAX_DEPTH=5

SECRET_KEY=change-me-in-production

# Optional: JWT_EXPIRE_MINUTES=1440
